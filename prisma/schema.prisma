generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth) ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

/// Emails allowed to complete SSO (Google / Microsoft). Managed in Configuración.
model SsoAllowedEmail {
  id              String   @id @default(cuid())
  email           String   @unique
  createdAt       DateTime @default(now())
  createdByUserId String?

  @@map("sso_allowed_emails")
}

// ─── Companies ─────────────────────────────────────────────────────────────────

model Company {
  id           String   @id @default(cuid())
  name         String
  holdedApiKey String
  currency     String   @default("EUR")
  active       Boolean  @default(true)

  invoices     Invoice[]
  suppliers    Supplier[]
  syncLogs     SyncLog[]
  proformas    Proforma[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("companies")
}

// ─── Jira Workspaces & Projects ────────────────────────────────────────────────

enum ProjectStatus {
  NOT_STARTED
  ONGOING
  PAUSED
  DONE
  ARCHIVED

  @@map("project_status")
}

model JiraWorkspace {
  id            String  @id @default(cuid())
  name          String
  domain        String
  email         String
  apiToken      String
  tempoApiToken String?
  active        Boolean @default(true)

  projects JiraProject[]
  syncLogs SyncLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("jira_workspaces")
}

model JiraProject {
  id          String        @id @default(cuid())
  jiraId      String
  jiraKey     String
  name        String
  workspaceId String
  workspace   JiraWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  active      Boolean       @default(true)
  status      ProjectStatus @default(NOT_STARTED)

  // Tipos de proyecto (no exclusivos entre sí)
  isPrecioCerrado  Boolean  @default(false)
  isBolsasHoras    Boolean  @default(false)
  isFeeRegular     Boolean  @default(false)

  // Precio cerrado
  fixedPrice          Decimal?
  budgetedHours       Float?
  fixedPriceInvoiceId String?
  fixedPriceInvoice   Invoice? @relation("FixedPriceInvoice", fields: [fixedPriceInvoiceId], references: [id], onDelete: SetNull)

  classifications              Classification[]
  userRoles                    ProjectUserRole[]
  proformas                    Proforma[]
  forecasts                    Forecast[]
  hourBuckets                  HourBucket[]
  regularFeeEntries            RegularFeeEntry[]
  issueHourBucketAssignments   IssueHourBucketAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([jiraId, workspaceId])
  @@index([workspaceId])
  @@index([status])
  @@index([fixedPriceInvoiceId])
  @@map("jira_projects")
}

model HourBucket {
  id             String       @id @default(cuid())
  projectId      String
  project        JiraProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleId         String
  role           RoleTemplate @relation(fields: [roleId], references: [id], onDelete: Restrict)
  code           String?      @unique
  totalHours     Float
  alertThreshold Float        @default(0.8)
  active         Boolean      @default(true)
  startDate      DateTime?
  endDate        DateTime?
  invoiceId      String?
  invoice        Invoice?     @relation("HourBucketInvoice", fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  issueAssignments IssueHourBucketAssignment[]

  @@index([projectId])
  @@index([invoiceId])
  @@map("hour_buckets")
}

model IssueHourBucketAssignment {
  id             String      @id @default(cuid())
  projectId      String
  project        JiraProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issueKey       String
  issueNumericId Int
  hourBucketId   String
  hourBucket     HourBucket  @relation(fields: [hourBucketId], references: [id], onDelete: Cascade)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([projectId, issueKey])
  @@index([projectId])
  @@index([hourBucketId])
  @@index([issueNumericId])
  @@map("issue_hour_bucket_assignments")
}

model RegularFeeEntry {
  id               String        @id @default(cuid())
  projectId        String
  project          JiraProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleId           String?
  role             RoleTemplate? @relation(fields: [roleId], references: [id], onDelete: SetNull)
  label            String
  monthlyFee       Decimal
  maxHoursPerMonth Float
  active           Boolean       @default(true)
  invoiceId        String?
  invoice          Invoice?      @relation("RegularFeeInvoice", fields: [invoiceId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([projectId])
  @@index([roleId])
  @@index([invoiceId])
  @@map("regular_fee_entries")
}

// ─── Invoices ──────────────────────────────────────────────────────────────────

enum InvoiceType {
  SALE
  PURCHASE
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  CLASSIFIED
  REVIEWED
  APPROVED
}

model Invoice {
  id           String        @id @default(cuid())
  holdedId     String
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  type         InvoiceType
  holdedStatus Int?
  status       InvoiceStatus @default(PENDING)

  number          String?
  counterparty    String?
  holdedContactId String?

  date         DateTime
  dueDate      DateTime?

  currency     String  @default("EUR")
  fxRateToEur  Decimal @default(1)
  subtotal     Decimal @default(0)
  tax          Decimal @default(0)
  total        Decimal @default(0)
  totalEur     Decimal @default(0)

  // Brand from Holded tags (mapped to readable name)
  marca           String?

  // Mes contable al que pertenece la factura (primer día del mes; por defecto el mes de date)
  accountingMonth DateTime?

  // Payment tracking (synced from Holded)
  paymentsTotal   Decimal @default(0)
  paymentsPending Decimal @default(0)

  lines              InvoiceLine[]
  auditLogs          AuditLog[]
  erpPayments        InvoicePayment[]
  verifications      SupplierVerification[]
  hourBuckets        HourBucket[]       @relation("HourBucketInvoice")
  fixedPriceProjects JiraProject[]      @relation("FixedPriceInvoice")
  regularFeeEntries  RegularFeeEntry[]  @relation("RegularFeeInvoice")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([holdedId, companyId])
  @@index([companyId])
  @@index([companyId, date])
  @@index([companyId, holdedContactId])
  @@index([date])
  @@index([accountingMonth])
  @@index([marca])
  @@index([status, type])
  @@map("invoices")
}

model InvoicePayment {
  id        String   @id @default(cuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount    Decimal
  paidAt    DateTime
  paidBy    String
  notes     String?

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@map("invoice_payments")
}

model InvoiceLine {
  id           String   @id @default(cuid())
  invoiceId    String
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  holdedLineId String?

  name        String
  description String?
  quantity    Decimal @default(1)
  unitPrice   Decimal @default(0)
  subtotal    Decimal @default(0)
  tax         Decimal @default(0)
  total       Decimal @default(0)
  totalEur    Decimal @default(0)

  accountingAccount     String?
  accountingAccountName String?
  notes                 String?

  sortOrder Int @default(0)

  classification Classification?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@map("invoice_lines")
}

// ─── Classification ────────────────────────────────────────────────────────────

enum ClassificationStatus {
  CLASSIFIED
  REVIEWED
  APPROVED
  IGNORED
}

model Classification {
  id            String               @id @default(cuid())
  invoiceLineId String               @unique
  invoiceLine   InvoiceLine          @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)
  projectId     String?
  project       JiraProject?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  marca         String?
  status        ClassificationStatus @default(CLASSIFIED)
  notes         String?

  classifiedBy String?
  reviewedBy   String?
  approvedBy   String?
  classifiedAt DateTime?
  reviewedAt   DateTime?
  approvedAt   DateTime?

  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([status])
  @@map("classifications")
}

// ─── Exchange Rates ────────────────────────────────────────────────────────────

model ExchangeRate {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  currency  String
  rateToEur Decimal

  @@unique([date, currency])
  @@map("exchange_rates")
}

// ─── Audit Log ─────────────────────────────────────────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  CLASSIFY
  REVIEW
  APPROVE
}

model AuditLog {
  id             String      @id @default(cuid())
  userId         String?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action         AuditAction
  entityType     String
  entityId       String
  previousValue  Json?
  newValue       Json?

  invoiceId        String?
  invoice          Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  classificationId String?
  classification   Classification? @relation(fields: [classificationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([invoiceId])
  @@index([classificationId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Supplier Verification ────────────────────────────────────────────────────

/// Proveedor sincronizado desde contactos Holded tipo "supplier", enriquecido con datos ERP.
model Supplier {
  id              String   @id @default(cuid())
  holdedContactId String
  companyId       String?
  company         Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)
  name            String

  hourlyRate    Decimal?
  tipo          SupplierTipo?

  defaultRoleId String?
  defaultRole   SupplierRole? @relation("SupplierDefaultRole", fields: [defaultRoleId], references: [id], onDelete: SetNull)

  isPartner Boolean  @default(false)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jiraUsers     SupplierJiraUser[]
  roles         SupplierRole[]
  verifications SupplierVerification[]

  @@unique([holdedContactId, companyId])
  @@index([companyId])
  @@map("suppliers")
}

model SupplierJiraUser {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  accountId  String
  createdAt  DateTime @default(now())

  @@unique([supplierId, accountId])
  @@map("supplier_jira_users")
}

model SupplierRole {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  name        String
  ratePerHour Decimal
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  verifications       SupplierVerification[]
  defaultForSuppliers Supplier[]             @relation("SupplierDefaultRole")

  @@index([supplierId])
  @@map("supplier_roles")
}

model ProjectUserRole {
  id            String       @id @default(cuid())
  projectId     String
  project       JiraProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  jiraAccountId String
  roleId        String
  role          RoleTemplate @relation(fields: [roleId], references: [id], onDelete: Cascade)
  ratePerHour   Decimal?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([projectId, jiraAccountId])
  @@index([projectId])
  @@map("project_user_roles")
}

/// Catálogo global de roles de proveedor, gestionable desde Configuración.
model RoleTemplate {
  id          String  @id @default(cuid())
  name        String
  color       String  @default("gray")
  ratePerHour Decimal @default(0)
  active      Boolean @default(true)

  hourBuckets       HourBucket[]
  projectUserRoles  ProjectUserRole[]
  regularFeeEntries RegularFeeEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("role_templates")
}

enum SupplierTipo {
  SERVICIOS
  HERRAMIENTAS

  @@map("supplier_tipo")
}


enum VerificationStatus {
  PENDING
  HOURS_CAPTURED
  INVOICE_RECEIVED
  PERIOD_MISMATCH
  VERIFIED_MISMATCH
  VERIFIED_OK
  APPROVED

  @@map("verification_status")
}

model SupplierVerification {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  roleId String?
  role   SupplierRole? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  periodStart DateTime
  periodEnd   DateTime

  tempoHours     Float?
  expectedAmount Decimal?
  capturedAt     DateTime?

  invoiceId      String?
  invoice        Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  invoicedAmount Decimal?

  invoiceServicePeriodStart DateTime?
  invoiceServicePeriodEnd   DateTime?
  periodMismatch            Boolean?

  status     VerificationStatus @default(PENDING)
  verifiedBy String?
  verifiedAt DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierId, periodStart, periodEnd])
  @@index([invoiceId])
  @@index([status])
  @@map("supplier_verifications")
}

// ─── Sync Logs ─────────────────────────────────────────────────────────────────

enum SyncSource {
  HOLDED
  JIRA
}

enum SyncResult {
  SUCCESS
  PARTIAL
  ERROR
}

model SyncLog {
  id             String         @id @default(cuid())
  source         SyncSource
  result         SyncResult
  companyId      String?
  company        Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  workspaceId    String?
  workspace      JiraWorkspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  invoicesSynced Int            @default(0)
  projectsSynced Int            @default(0)
  errorMessage   String?
  triggeredBy    String?
  startedAt      DateTime
  finishedAt     DateTime?

  @@index([companyId])
  @@index([workspaceId])
  @@index([source, startedAt])
  @@map("sync_logs")
}

// ─── Proformas (Holded) ───────────────────────────────────────────────────────

model Proforma {
  id              String       @id @default(cuid())
  holdedId        String
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)

  number          String?
  counterparty    String?
  holdedContactId String?
  holdedStatus    Int?

  date            DateTime
  dueDate         DateTime?

  currency        String   @default("EUR")
  fxRateToEur     Decimal  @default(1)
  subtotal        Decimal  @default(0)
  tax             Decimal  @default(0)
  total           Decimal  @default(0)
  totalEur        Decimal  @default(0)

  description     String?
  tags            String[]

  marca           String?
  projectId       String?
  project         JiraProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  notes           String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([holdedId, companyId])
  @@index([companyId])
  @@index([companyId, date])
  @@index([marca])
  @@map("proformas")
}

// ─── Previsiones ERP ─────────────────────────────────────────────────────────

enum ForecastType {
  INCOME
  EXPENSE

  @@map("forecast_type")
}

model Forecast {
  id                String       @id @default(cuid())
  month             DateTime
  type              ForecastType
  marca             String?
  projectId         String?
  project           JiraProject? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  description       String?
  amountOptimistic  Decimal
  amountPessimistic Decimal

  createdBy         String?
  updatedBy         String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([month])
  @@index([marca])
  @@map("forecasts")
}

// ─── Account Mappings ──────────────────────────────────────────────────────────

model AccountMapping {
  id            String  @id @default(cuid())
  tag           String  @unique
  description   String
  l1            String
  accountNumSL  String?
  accountNameSL String?
  accountNumOU  String?
  accountNameOU String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("account_mappings")
}
