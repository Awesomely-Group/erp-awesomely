# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/erp_awesomely?schema=public"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth — https://console.cloud.google.com/
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Microsoft Entra ID — https://portal.azure.com/
AUTH_MICROSOFT_ENTRA_ID=""
AUTH_MICROSOFT_ENTRA_SECRET=""
AUTH_MICROSOFT_ENTRA_TENANT_ID="common"

# Comma-separated emails allowed to edit SSO allowlist in Configuración (default: jaume@somosgigson.com)
SSO_ALLOWLIST_ADMIN_EMAILS=""

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Secret to authenticate Vercel cron calls — generate with: openssl rand -base64 32
CRON_SECRET=""
